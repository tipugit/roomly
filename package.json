{
  "name": "roomly",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api:dev": "php -S localhost:8080 -t api",
    "build": "tsc -b && vite build && cp -R api dist/api",
    "preview": "vite preview",
    "deploy:pack": "npm run build && cd dist && zip -r ../roomly-deploy.zip . && cd .. && echo 'Upload roomly-deploy.zip contents to public_html'"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.487.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.2",
    "tailwind-merge": "^3.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5.7.3",
    "vite": "^6.3.5"
  }
}
